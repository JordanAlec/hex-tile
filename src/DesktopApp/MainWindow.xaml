<Window x:Class="DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:screens="clr-namespace:DesktopApp.Screens"
        Icon="Assets/logo.ico"
        Title="HexTile"
        Height="1000"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        BorderBrush="{StaticResource BorderColor}"
        BorderThickness="1">

    <DockPanel LastChildFill="True">

        <!-- ================= MENU ================= -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Actions">
                <MenuItem Header="_Settings"
                          Click="Settings_Click"/>

                <MenuItem Header="_Always on Top"
                          IsCheckable="True"
                          Click="AlwaysOnTop_Click"/>

                <MenuItem Header="_About"
                          Click="About_Click"/>

                <MenuItem Header="E_xit"
                          Click="Exit_Click"/>
            </MenuItem>
        </Menu>

        <!-- =============== HEADER ================= -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BackgroundMedium}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Margin="0,0,0,0">
            <StackPanel HorizontalAlignment="Center"
                        Margin="0,32,0,32">

                <TextBlock x:Name="TitleText"
                           Text="HexTile"
                           FontSize="48"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>

                <TextBlock x:Name="SubTitleText"
                           Text="Control your HX Stomp foot switches when you can't get near them!"
                           FontSize="16"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,0"/>

                <TextBlock x:Name="ErrorTextBlock"
                           Text=""
                           Foreground="{StaticResource AccentRed}"
                           FontSize="15"
                           FontWeight="Bold"
                           Visibility="Collapsed"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>
            </StackPanel>
        </Border>

        <!-- =========== SCREEN SELECTOR BUTTONS =========== -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BackgroundMedium}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="0,16,0,16">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button x:Name="NavigationButton"
                        Click="NavigationScreen_Click"
                        Width="150"
                        Height="40"
                        Style="{StaticResource TabButtonStyle}"
                        Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Navigation"
                                                    Width="20"
                                                    Height="20"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center"/>
                        <TextBlock Text="Navigation"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="FootswitchButton"
                        Click="FootswitchScreen_Click"
                        Width="150"
                        Height="40"
                        Style="{StaticResource TabButtonStyle}"
                        Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="GestureTapButton"
                                                    Width="20"
                                                    Height="20"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center"/>
                        <TextBlock Text="Footswitches"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SnapshotButton"
                        Click="SnapshotScreen_Click"
                        Width="150"
                        Height="40"
                        Style="{StaticResource TabButtonStyle}"
                        Margin="4">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Camera"
                                                    Width="20"
                                                    Height="20"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center"/>
                        <TextBlock Text="Snapshots"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- =========== SCREENS =========== -->
        <Border Background="{StaticResource BackgroundDark}"
                Padding="24">
            <ContentControl>
                <Grid>
                    <ContentControl x:Name="NavigationScreenControl" 
                                   Visibility="Visible"/>
                    <ContentControl x:Name="FootswitchScreenControl" 
                                   Visibility="Collapsed"/>
                    <ContentControl x:Name="SnapshotScreenControl" 
                                   Visibility="Collapsed"/>
                </Grid>
            </ContentControl>
        </Border>

    </DockPanel>
</Window>
