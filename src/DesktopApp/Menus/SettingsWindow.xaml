<Window x:Class="DesktopApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="{StaticResource BackgroundDark}"
            BorderBrush="{StaticResource BorderAccent}"
            BorderThickness="1">
        <StackPanel Margin="32,24,32,24">

            <TextBlock Text="Settings"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,24"/>

            <!-- MIDI Base Channel -->
            <TextBlock Text="MIDI Base Channel"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

            <TextBlock Text="Select the MIDI channel your HX Stomp is configured to receive on."
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="12"
                       MaxWidth="320"
                       Margin="0,0,0,8"/>

            <ComboBox x:Name="MidiChannelComboBox"
                      Width="120"
                      Height="32"
                      HorizontalAlignment="Left"
                      Margin="0,0,0,24"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Width="100"
                        Height="40"
                        Style="{StaticResource TabButtonStyle}"
                        Margin="0,0,8,0"
                        Click="Cancel_Click"/>
                <Button Content="Save"
                        Width="100"
                        Height="40"
                        Style="{StaticResource TabButtonStyle}"
                        Click="Save_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
