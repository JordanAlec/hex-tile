<Window x:Class="DesktopApp.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="{StaticResource BackgroundDark}" 
            BorderBrush="{StaticResource BorderAccent}" 
            BorderThickness="1">
        <StackPanel Margin="32,24,32,24">
            <TextBlock Text="HexTile"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,12"/>

            <TextBlock Text="Version 1.0.1"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="13"/>
            <TextBlock Text="JordanAlec"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="13"
                       Margin="0,8,0,0"/>
            <TextBlock Text="https://github.com/JordanAlec/hex-tile"
                       Foreground="{StaticResource AccentRed}"
                       FontSize="13"
                       Margin="0,4,0,0"/>

            <TextBlock Text="Control your HX Stomp foot switches when you can't get near them!"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="13"
                       MaxWidth="350"
                       Margin="0,16,0,12"/>

            <Border Background="{StaticResource AccentRed}" 
                    BorderThickness="2"
                    BorderBrush="{StaticResource AccentRed}"
                    Padding="12"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="⚠️ THIS SOFTWARE IS FREE"
                               FontWeight="Bold"
                               FontSize="14"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="If you paid money for HexTile, you have been scammed. It is and always will be free and open source."
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               MaxWidth="320"/>
                </StackPanel>
            </Border>

            <Button Content="OK"
                    Width="120"
                    Height="50"
                    HorizontalAlignment="Right"
                    Style="{StaticResource TabButtonStyle}"
                    Click="Ok_Click"/>
        </StackPanel>
    </Border>
</Window>