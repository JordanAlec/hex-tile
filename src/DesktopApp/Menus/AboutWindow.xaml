<Window x:Class="DesktopApp.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="{StaticResource BackgroundDark}" 
            BorderBrush="{StaticResource BorderAccent}" 
            BorderThickness="1">
        <StackPanel Margin="32,24,32,24">
            <TextBlock Text="HexTile"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary}"
                       Margin="0,0,0,12"/>

            <TextBlock Text="Version 0.0.1 - PreRelease"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="13"/>
            <TextBlock Text="JordanAlec"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="13"
                       Margin="0,8,0,0"/>
            <TextBlock Text="https://github.com/JordanAlec/hex-tile"
                       Foreground="{StaticResource AccentRed}"
                       FontSize="13"
                       Margin="0,4,0,0"/>

            <TextBlock Text="Control your HX Stomp foot switches when you can't get near them!"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondary}"
                       FontSize="13"
                       MaxWidth="350"
                       Margin="0,16,0,20"/>

            <Button Content="OK"
                    Width="100"
                    Height="32"
                    HorizontalAlignment="Right"
                    Style="{StaticResource TabButtonStyle}"
                    Click="Ok_Click"/>
        </StackPanel>
    </Border>
</Window>