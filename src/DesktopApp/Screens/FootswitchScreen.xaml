                    <iconPacks:PackIconMaterial
                        Kind="Numeric2Box"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Footswitch 2"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Button>

