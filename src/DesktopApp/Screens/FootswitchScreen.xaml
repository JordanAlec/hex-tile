                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="(XL only)"
                               Style="{StaticResource MutedTextStyle}"
