                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Footswitch 3"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Footswitch 4 -->
