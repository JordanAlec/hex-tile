<local:BaseScreen x:Class="DesktopApp.Screens.FootswitchScreen"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:local="clr-namespace:DesktopApp.Screens">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <UniformGrid Rows="3"
                     Columns="3"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top"
                     Margin="0,12,0,12">

            <!-- Footswitch 1 -->
            <Button Click="FS1_Click" 
                    Style="{StaticResource TileButtonStyle}"
                    Width="220"
                    Height="180"
                    Margin="12">
                <StackPanel>
                    <iconPacks:PackIconMaterial
                        Kind="Numeric1Box"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Footswitch 1"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Footswitch 2 -->
            <Button Click="FS2_Click" 
                    Style="{StaticResource TileButtonStyle}"
                    Width="220"
                    Height="180"
                    Margin="12">
