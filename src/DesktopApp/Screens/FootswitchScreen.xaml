<local:BaseScreen x:Class="DesktopApp.Screens.FootswitchScreen"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:local="clr-namespace:DesktopApp.Screens">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <UniformGrid Rows="3"
                     Columns="3"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top">

            <!-- Footswitch 1 -->
            <Border CornerRadius="8"
                    Background="White"
                    Margin="8"
                    Padding="4"
                    Width="200"
                    Height="150"
                    BorderBrush="Gray"
                    BorderThickness="1">
                <Button Click="FS1_Click" Cursor="Hand">
                    <StackPanel>
                        <iconPacks:PackIconMaterial
                            Kind="Numeric1Box"
                            Width="40"
                            Height="40"
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center"/>
                        <TextBlock Text="Footswitch 1"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>

            <!-- Footswitch 2 -->
            <Border CornerRadius="8"
                    Background="White"
                    Margin="8"
                    Padding="4"
