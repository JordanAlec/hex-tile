<local:BaseScreen x:Class="DesktopApp.Screens.SnapshotScreen"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:local="clr-namespace:DesktopApp.Screens">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <UniformGrid Rows="2"
                     Columns="3"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Top"
                     Margin="0,12,0,12">

            <!-- Snapshot 1 -->
            <Button Click="Snapshot1_Click" 
                    Style="{StaticResource TileButtonStyle}"
                    Width="220"
                    Height="180"
                    Margin="12">
                <StackPanel>
                    <iconPacks:PackIconMaterial
                        Kind="Numeric1Box"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Snapshot 1"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Snapshot 2 -->
            <Button Click="Snapshot2_Click" 
                    Style="{StaticResource TileButtonStyle}"
                    Width="220"
                    Height="180"
                    Margin="12">
                <StackPanel>
                    <iconPacks:PackIconMaterial
                        Kind="Numeric2Box"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Snapshot 2"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Snapshot 3 -->
            <Button Click="Snapshot3_Click" 
                    Style="{StaticResource TileButtonStyle}"
                    Width="220"
                    Height="180"
                    Margin="12">
                <StackPanel>
                    <iconPacks:PackIconMaterial
                        Kind="Numeric3Box"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Snapshot 3"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Snapshot 4 -->
            <Button Click="Snapshot4_Click" 
                    Style="{StaticResource TileButtonStyle}"
                    Width="220"
                    Height="180"
                    Margin="12">
                <StackPanel>
                    <iconPacks:PackIconMaterial
                        Kind="Numeric4Box"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Snapshot 4"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="(XL only)"
                               Style="{StaticResource MutedTextStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Button>

            <!-- Previous Snapshot -->
            <Button Click="PreviousSnapshot_Click" 
                    Style="{StaticResource TileButtonStyle}"
                    Width="220"
                    Height="180"
                    Margin="12">
                <StackPanel>
                    <iconPacks:PackIconMaterial
                        Kind="ArrowDownBoldBox"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Previous Snapshot"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Next Snapshot -->
            <Button Click="NextSnapshot_Click" 
                    Style="{StaticResource TileButtonStyle}"
                    Width="220"
                    Height="180"
                    Margin="12">
                <StackPanel>
                    <iconPacks:PackIconMaterial
                        Kind="ArrowUpBoldBox"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Next Snapshot"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Button>
        </UniformGrid>
    </ScrollViewer>
</local:BaseScreen>
