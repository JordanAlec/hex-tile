<local:BaseScreen x:Class="DesktopApp.Screens.NavigationScreen"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                xmlns:local="clr-namespace:DesktopApp.Screens">
    
    <Grid>
        <UniformGrid Rows="1"
                     Columns="3"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">

            <!-- Tuner Tile -->
            <Button Click="ToggleTuner_Click" 
                    Style="{StaticResource TileButtonStyle}"
                    Width="220"
                    Height="180"
                    Margin="12">
                <StackPanel>
                    <iconPacks:PackIconMaterial
                        Kind="Knob"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Toggle Tuner"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Previous Preset Tile -->
            <Button Click="PreviousPreset_Click" 
                    Style="{StaticResource TileButtonStyle}"
                    Width="220"
                    Height="180"
                    Margin="12">
                <StackPanel>
                    <iconPacks:PackIconMaterial
                        Kind="ArrowDownBoldBox"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Previous Preset"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Button>

            <!-- Next Preset Tile -->
            <Button Click="NextPreset_Click" 
                    Style="{StaticResource TileButtonStyle}"
                    Width="220"
                    Height="180"
                    Margin="12">
                <StackPanel>
                    <iconPacks:PackIconMaterial
                        Kind="ArrowUpBoldBox"
                        Width="50"
                        Height="50"
                        Margin="0,0,0,16"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Next Preset"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Button>
        </UniformGrid>
    </Grid>
</local:BaseScreen>
