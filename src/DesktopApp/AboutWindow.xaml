<Window x:Class="DesktopApp.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock Text="HexTile"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <TextBlock Text="Version 0.0.1 - PreRelease"/>
        <TextBlock Text="JordanAlec"
                   Margin="0,5,0,0"/>
        <TextBlock Text="https://github.com/JordanAlec/hex-tile"
                   Margin="0,5,0,0"/>

        <TextBlock Text="Control your HX Stomp foot switches when you can't get near them!"
                   TextWrapping="Wrap"
                   Margin="0,10,0,10"/>

        <Button Content="OK"
                Width="80"
                HorizontalAlignment="Right"
                Click="Ok_Click"/>
    </StackPanel>
</Window>